	},
	"item": [
		{
			"name": "1. PokeAPI",
			"item": [
				{
					"name": "Obtener Lista General de Pokémon",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:5001/api/pokemon",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "5001",
							"path": [
								"api",
								"pokemon"
							]
						},
						"description": "Consultar a la PokeAPI externa para recuperar una lista paginada de 50 Pokémon junto con sus sprites."
					}
				},
				{
					"name": "Obtener Detalle de Pokémon",
					"request": {
						"method": "GET",
						"header": [],
